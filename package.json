{
  "name": "listing-photo-ranker",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @listing-photo-ranker/web",
    "build": "npm run build --workspace @listing-photo-ranker/web",
    "smoke:vercel": "npm run build",
    "test": "node --import tsx --test ./tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
