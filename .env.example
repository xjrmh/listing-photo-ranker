# Required for Vercel deployment: use a durable app URL, database, and object storage.
# The in-memory defaults are fine for local development but are not sufficient on Vercel.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
DATABASE_URL=
# Optional: fail faster when Postgres is unreachable. Defaults to 5000ms.
DATABASE_CONNECT_TIMEOUT_MS=5000
# Set this to `s3` on Vercel.
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional on Vercel. External API and CLI clients must send `x-api-key` when set.
API_KEY=
S3_ENDPOINT=
QUEUE_PROVIDER=inline
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
LLM_JUDGE_MODEL=gpt-5.4
